{
  "name": "bigfoot-connect",
  "version": "1.4.9",
  "main": "main.js",
  "productName": "BIGFOOT Connect",
  "description": "Run a node and earn BIG.",
  "author": "BIGFOOT",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "pack": "cross-env NODE_ENV=production electron-builder --dir",
    "dist": "cross-env NODE_ENV=production electron-builder",
    "dist-publish": "cross-env NODE_ENV=production electron-builder --publish=always",
    "install:prod": "npm ci --omit=dev",
    "audit": "npm audit --audit-level=high"
  },
  "build": {
    "appId": "tech.bigfoot.connect.app",
    "productName": "BIGFOOT Connect",
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "compression": "maximum",
    "publish": [
      {
        "provider": "github",
        "owner": "fabricioricard",
        "repo": "BIGFOOT-Connect"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "*.html",
      "*.css",
      "assets/**/*",
      "package.json",
      "!**/*.map",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/coverage/**",
      "!.env",
      "!.env.*"
    ],
    "asarUnpack": [
      "node_modules/@solana/**/*",
      "node_modules/firebase/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true,
      "perMachine": false
    }
  },
  "devDependencies": {
    "cross-env": "7.0.3",
    "electron": "^37.10.3",
    "electron-builder": "26.0.12"
  },
  "dependencies": {
    "@solana/spl-token": "0.4.14",
    "@solana/web3.js": "1.98.4",
    "axios": "^1.16.1",
    "combined-stream": "1.0.8",
    "dotenv": "16.4.5",
    "electron-is-dev": "2.0.0",
    "electron-squirrel-startup": "1.0.1",
    "electron-updater": "^6.8.3",
    "firebase": "11.10.0",
    "follow-redirects": "^1.16.0",
    "node-fetch": "2.7.0",
    "speedtest-net": "2.2.0"
  }
}
